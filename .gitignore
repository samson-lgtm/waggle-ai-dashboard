# Desktop specific: Ignore other Desktop files (highly recommended for safety)
# This ignores EVERYTHING by default, then we whitelist the project files
/*
!/src/
!/package.json
!/package-lock.json
!/vite.config.ts
!/index.html
!/postcss.config.mjs
!/public/
!/scripts/
!/.gitignore
!/README.md
!/ATTRIBUTIONS.md
!/guidelines/
